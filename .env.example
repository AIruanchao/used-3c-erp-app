# Sentry DSN (leave empty to disable error reporting)
EXPO_PUBLIC_SENTRY_DSN=

# Optional: override API base (recommended for EAS test builds and physical-device local dev)
# Example (LAN dev server for a physical iPhone): http://192.168.1.10:3000
# Example (staging / alternate prod host): https://your-api.example.com
EXPO_PUBLIC_API_BASE=
