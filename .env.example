# Sentry DSN (leave empty to disable error reporting)
EXPO_PUBLIC_SENTRY_DSN=

# Optional: override API base (recommended for EAS test builds and physical-device local dev)
# Example (LAN dev server for a physical iPhone): http://192.168.1.10:3000
# Example (staging / alternate prod host): https://your-api.example.com
EXPO_PUBLIC_API_BASE=

# Local log drain (JSON POST). Point this at your own tiny HTTP server to collect logs.
# Example: http://192.168.1.10:7242/logs
EXPO_PUBLIC_LOG_DRAIN_URL=
# Default: on in __DEV__ when EXPO_PUBLIC_LOG_DRAIN_URL is set; in production default off unless you set this to 1
EXPO_PUBLIC_LOG_DRAIN_ENABLE=
# Optional tuning
EXPO_PUBLIC_LOG_DRAIN_INTERVAL_MS=5000
EXPO_PUBLIC_LOG_DRAIN_MAX_BATCH=50
EXPO_PUBLIC_LOG_DRAIN_FLUSH_ON_APPSTATE=1
